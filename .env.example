# =============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!
# =============================================================

# --- LLM Provider ---
# Option A: Google AI Studio (Gemini) — FREE TIER
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Option B: OpenRouter (alternative free models)
# Get your key at: https://openrouter.ai/
# OPENROUTER_API_KEY=your_openrouter_key_here

# --- LLM Configuration ---
LLM_PROVIDER=gemini             # Options: gemini | openrouter
LLM_MODEL=gemini-2.5-flash      # Primary model name
# LLM_BACKUP_PROVIDER=openrouter
# LLM_BACKUP_MODEL=google/gemini-2.5-flash:free

# --- Retrieval Configuration ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
QDRANT_PATH=./data/qdrant_storage
BM25_INDEX_PATH=./data/bm25_index.pkl
COLLECTION_NAME=langchain_docs

# --- Retrieval Hyperparameters ---
VECTOR_TOP_K=25        # Results from vector search per retriever call
BM25_TOP_K=25          # Results from BM25 per retriever call
RERANKER_TOP_K=5       # Final top-k after cross-encoder reranking

# --- Memory (v2) ---
MEMORY_MAX_HISTORY=10  # Max messages retained per session

# --- Web Search (v2, optional) ---
# Get a free Tavily key at: https://tavily.com/
# TAVILY_API_KEY=your_tavily_key_here
# WEB_SEARCH_PROVIDER=tavily   # Options: tavily | brave

# --- Workspace Storage (v2) ---
WORKSPACE_STORE_PATH=./data/workspaces.json

# --- Observability (v2, optional) ---
# LANGSMITH_API_KEY=your_langsmith_key_here
# LANGSMITH_TRACING=false
# LANGSMITH_PROJECT=askmydocs-rag-v2

# --- Evaluation Thresholds ---
MIN_FAITHFULNESS=0.75
MIN_ANSWER_RELEVANCE=0.70
